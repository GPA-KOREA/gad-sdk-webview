{
  "name": "gad-offerwall-webview-sdk",
  "version": "0.1.0",
  "description": "GAD Offerwall WebView SDK (Gad.Ofw) — 네이티브 WebView 브리지 래퍼. 애디슨 Adison.Ofw 와 동형.",
  "type": "module",
  "main": "./dist/gad-ofw-sdk.umd.js",
  "module": "./dist/gad-ofw-sdk.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/gad-ofw-sdk.es.js",
      "require": "./dist/gad-ofw-sdk.umd.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.dts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "serve": "vite build && npx --yes http-server . -p 3000 -o /sample/index.html"
  },
  "license": "Apache-2.0",
  "author": "GPA KOREA",
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^3.1.0"
  }
}
